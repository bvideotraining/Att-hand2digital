rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'bvideotraining@gmail.com' ||
        request.auth.token.email == 'hr.totscollege@gmail.com'
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles - only owner or admin can write, authenticated users can read
    match /user_profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // User data - only owner or admin can access
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Allow public newsletter submissions
    match /users/{userId}/newsletterResponses/{responseId} {
      allow create: if true; // Anyone can subscribe
    }
    
    // Legacy app_data
    match /app_data/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Public configuration - readable by everyone, writable only by admin
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
