rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == 'bvideotraining@gmail.com' ||
         (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'Admin'));
    }

    // Global User Profiles for Activation/Management
    match /user_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      request.resource.data.email == request.auth.token.email &&
                      (
                        (request.auth.token.email == 'bvideotraining@gmail.com' && 
                         request.resource.data.role == 'Admin' && 
                         request.resource.data.status == 'active') ||
                        (request.resource.data.role == 'HR User' && 
                         request.resource.data.status == 'pending')
                      );
      allow update: if isAdmin();
    }

    // Rules for user-specific data
    // This matches the user document and all its subcollections recursively
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Backward compatibility for migration
    match /app_data/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /app_data/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Public configuration for unauthenticated users
    match /public/config {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
